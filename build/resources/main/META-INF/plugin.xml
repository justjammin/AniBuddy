<idea-plugin>
  <idea-version since-build="243" />
  <version>0.1.0</version>
  <id>com.justjammin.anibuddy</id>
  <name>Anibuddy</name>
  <vendor>justjammin</vendor>
  <description>VRM anime avatars that visualize Claude Code agent activity in real time</description>
  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
    <toolWindow id="AniBuddy" factoryClass="com.justjammin.anibuddy.AnimeAgentToolWindowFactory" anchor="right" canCloseContents="false" icon="/icons/aniBuddy.svg" />
    <projectService serviceImplementation="com.justjammin.anibuddy.TranscriptWatcherService" />
    <projectService serviceImplementation="com.justjammin.anibuddy.AniBuddySettings" />
    <projectConfigurable parentId="tools" instance="com.justjammin.anibuddy.AniBuddyConfigurable" displayName="AniBuddy Agents" id="com.justjammin.anibuddy.settings" />
    <postStartupActivity implementation="com.justjammin.anibuddy.TranscriptWatcherStartup" />
  </extensions>
  <actions>
    <group id="com.justjammin.anibuddy.ToolsGroup" text="AniBuddy" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last" />
      <action id="com.justjammin.anibuddy.LoadVRMAction" class="com.justjammin.anibuddy.LoadVRMAction" text="Load VRM Model..." description="Select a .vrm file to use as your anime avatar" />
      <action id="com.justjammin.anibuddy.SetBackgroundAction" class="com.justjammin.anibuddy.SetBackgroundAction" text="Set Agent Background Image..." description="Set a background image for the active agent" />
      <action id="com.justjammin.anibuddy.RenameAgentAction" class="com.justjammin.anibuddy.RenameAgentAction" text="Rename Active Agent..." description="Rename the currently selected anime agent" />
    </group>
  </actions>
</idea-plugin>
